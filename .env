# =============================================================================
#  .env.example – copy to .env and fill in real values before running prod
#
#  Usage:
#    cp .env.example .env
#    # edit .env with real credentials
#    docker compose --profile prod up -d
#
#  ⚠  NEVER commit .env to version control (it is in .gitignore)
# =============================================================================

# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (used only when SPRING_PROFILES_ACTIVE=prod)
DB_URL=jdbc:postgresql://postgres:5432/performancepulse
DB_USER=pulse_user
DB_PASSWORD=changeme

# pgAdmin web UI (used only when SPRING_PROFILES_ACTIVE=prod)
PGADMIN_PASSWORD=admin
